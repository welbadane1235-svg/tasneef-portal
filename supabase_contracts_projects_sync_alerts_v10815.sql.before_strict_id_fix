  'active_alerts',(select count(*) from public.contract_expiry_notifications where status<>'resolved'),
  'resolved_alerts',(select count(*) from public.contract_expiry_notifications where status='resolved'),
  'duplicate_alerts_resolved',(select count(*) from public.contract_expiry_notifications where resolution='duplicate_merged'),
  'stopped_projects_visible_in_contracts',(select count(*) from public.projects where is_active=false)
) as result;
